rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Item photos: owner can upload/delete, anyone authed can read
    match /items/{itemId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Borrow photos: participants can upload, anyone authed can read
    match /borrows/{borrowId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Profile photos: owner can upload/delete, anyone authed can read
    match /profiles/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
