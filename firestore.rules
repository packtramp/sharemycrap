rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: any authenticated user can read (for friend code lookup), only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friends subcollection
    match /users/{userId}/friends/{friendId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
    }

    // Items: owner can CRUD, authenticated users can read (for browse)
    match /items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Groups: members can read, authenticated users can create
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.memberIds;

      // Group members subcollection
      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
    }

    // Approved tags
    match /approvedTags/{tagId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Tag suggestions
    match /tagSuggestions/{suggestionId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Borrows: any authenticated user can read/create; only owner or borrower can update
    match /borrows/{borrowId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid || resource.data.borrowerId == request.auth.uid);
    }
  }
}
